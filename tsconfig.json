{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./src/*"],
      "@/atlas/*": ["./src/atlas/*"],
      "@/modules/*": ["./src/modules/*"],
      "@/assets/*": ["./assets/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"],
  "exclude": [
    "scripts/**",
    "engineering/packages/**/proposed-changes/**",
    "engineering/packages/**/applied-*/**",
    "**/*.test.ts"
  ]
}
