# Copy to .env and add your key. Never commit .env
ANTHROPIC_API_KEY=your_api_key_here

# Sprint 0.1 · Executive Memory base URL. Defaults to localhost if unset — only needed for
# testing on a physical mobile device, where it must be the dev machine's LAN IP instead.
# EXECUTIVE_MEMORY_BASE_URL=http://192.168.1.23:8792
